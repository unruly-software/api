{
  "name": "@unruly-software/api-client",
  "packageManager": "yarn@3.5.0",
  "version": "2.0.3",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "description": "Modelling Typescript value objects on top of Zod schemas. Define a type once, get runtime validation, a real class you can attach methods to, and lossless JSON.stringify round-tripping — without writing boilerplate.",
  "scripts": {
    "build": "rm -rf ./dist && tsc --noEmit && microbundle",
    "build:watch": "tsc --noEmit --watch",
    "clean": "rm -rf ./dist",
    "test": "vitest"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "3.2.4",
    "microbundle": "0.15.1",
    "typescript": "5.0.4",
    "vitest": "3.2.4",
    "zod": "^4.0.0"
  },
  "amdName": "api-client",
  "main": "dist/api-client.js",
  "module": "dist/api-client.module.js",
  "types": "dist/index.d.ts",
  "umd:main": "dist/api-client.umd.js",
  "source": "src/index.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "umd": "./dist/api-client.umd.js",
      "import": "./dist/api-client.mjs",
      "require": "./dist/api-client.js"
    }
  }
}
